{
  "name": "@webhooks/api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "node --watch --import=tsx --env-file=../../.env src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.49.8",
    "@webhooks/env": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  }
