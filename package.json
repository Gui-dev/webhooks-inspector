{
  "name": "webhooks",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "clean": "turbo clean",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write --unsafe",
    "format": "turbo format",
    "format:check": "turbo format:check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "tslib": "^2.8.1",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
